// Prisma スキーマ（③/① システム永続化）
// 開発は SQLite。本番は DATABASE_URL を Postgres 等に切り替え、provider を変更する。
// layout 系は JSON 文字列として保存（SQLite 互換重視）。リポジトリ層で parse/stringify する。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("user") // 'admin'（管理者: ページ編集+ユーザー管理） | 'user'（利用者: ページ編集のみ）
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 案件（プロジェクト/申請等）— 必要書類を束ねる単位
model Project {
  id          String     @id @default(cuid())
  name        String
  description String?
  owner       String? // 担当
  dueDate     DateTime? // 期限
  documents   Document[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// 必要書類（案件に紐づく。status で進捗を表す）
model Document {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  docType   String? // 種類
  status    String    @default("not_started") // not_started | in_progress | reviewing | done
  assignee  String? // 担当
  dueDate   DateTime?
  note      String?
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([projectId])
}

model Page {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String? // SEO用メタ説明文（null = 本文から自動生成）
  status          String   @default("draft") // 'draft' | 'published'
  draftLayout     String   @default("[]") // JSON 文字列（PageLayout）
  publishedLayout String? // JSON 文字列（PageLayout）または null
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
