# ===== 本番(Vercel)環境変数テンプレート =====
# Vercel のプロジェクト設定 > Environment Variables に登録する（このファイル自体はデプロイ不要）。

# マネージドPostgres（アプリ実行時用：プール接続を推奨）
# 例(Neon): postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# マイグレーション用の直結URL（プールを通さない。migrate deploy が使用）
# 例(Neon): pooler ではない方のホスト
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# セッション署名鍵（必ず十分長いランダム値を生成: openssl rand -base64 48）
SESSION_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"

# 公開URL（OGP/canonical/サイトマップの絶対URLに使用）
NEXT_PUBLIC_SITE_URL="https://your-portal.example.com"

# 初期管理者（seed投入後は速やかに変更すること）
ADMIN_EMAIL="admin@example.co.jp"
ADMIN_PASSWORD="REPLACE_WITH_STRONG_PASSWORD"
